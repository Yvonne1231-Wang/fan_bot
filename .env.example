# ==========================================
# LLM Provider Configuration
# ==========================================

# 选择 LLM 提供商 (anthropic 或 ark)
LLM_PROVIDER=anthropic

# ==========================================
# Option 1: Anthropic Claude
# ==========================================
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ==========================================
# Option 2: Ark (字节跳动火山引擎)
# ==========================================
# ARK_API_KEY=your-ark-api-key
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=ep-your-endpoint-id

# ==========================================
# Tavily Web Search API (Optional)
# ==========================================
TAVILY_API_KEY=tvly-your-api-key-here

# ==========================================
# Debug Settings (Optional)
# ==========================================
# 调试日志输出，支持命名空间过滤
# DEBUG=*                     启用所有调试输出
# DEBUG=agent:*              只启用 agent 模块
# DEBUG=agent:loop,llm:*     只启用特定模块
# DEBUG=                     禁用所有调试输出（默认）
# DEBUG=agent:loop

# ==========================================
# Session & Transport Settings (Optional)
# ==========================================
# TRANSPORT=cli
# HTTP_PORT=3000
# SESSION_DIR=./sessions
# MAX_CONTEXT_MESSAGES=40

# ==========================================
# Agent Settings (Optional)
# ==========================================
# Agent 最大迭代次数，默认 10
# 超过此数值任务将终止，防止无限循环
# MAX_AGENT_ITERATIONS=10

# ==========================================
# Memory Service (Optional)
# ==========================================
# Jina API Key，用于 embeddings 加速搜索
JINA_API_KEY=jina_xxx

# ==========================================
# Cron Security Settings (Optional)
# ==========================================
# HMAC 密钥，用于对 cron 任务进行签名验证
# 不配置：签名功能禁用，cron 任务可被任意篡改后执行
# 配置后：每次任务执行前会验证签名，篡改过的任务将被拒绝
# CRON_HMAC_SECRET=your-secret-key-here

# ==========================================
# Permission Settings (Optional)
# ==========================================
# 管理员用户 ID（逗号分隔），管理员拥有所有权限
# CLI 模式默认用户: cli-user
# HTTP 模式默认用户: http-user
# ADMINS=cli-user,http-user

# ==========================================
# Feishu Configuration (Optional)
# ==========================================
# 传输模式: cli, http, feishu
# TRANSPORT=feishu

# 飞书应用配置（从飞书开放平台获取）
# FEISHU_APP_ID=cli_xxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 是否使用国际版 Lark（默认 false，使用国内飞书）
# FEISHU_USE_LARK=false

# 飞书事件订阅配置（可选）
# FEISHU_ENCRYPT_KEY=xxxxxxxx
# FEISHU_VERIFICATION_TOKEN=xxxxxxxx

# 飞书群聊白名单（逗号分隔，为空则拒绝所有群聊）
# FEISHU_GROUP_WHITELIST=oc_xxxxxxxxxxxx,oc_yyyyyyyyyyyy

# 是否允许群聊直接调用（不 @ 机器人）
# FEISHU_ALLOW_DIRECT_CALL=false

# 是否启用流式卡片
# ENABLE_STREAMING_CARD=true

# ==========================================
# Lark CLI 配置 (Optional)
# ==========================================
# lark-cli 的配置存储在 ~/.lark-cli/ 目录
# 使用以下命令初始化:
#   npm run feishu:config  (初始化配置)
#   npm run feishu:login   (登录授权)
#   npm run feishu:status  (查看状态)
# 不需要在 .env 中配置，lark-cli 有独立凭据管理