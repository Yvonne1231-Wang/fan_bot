{
  "name": "fan_bot",
  "version": "1.0.0",
  "description": "A lightweight, framework-free AI agent written in TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "smoke": "tsx src/agent/smoke_test.ts",
    "smoke:agent": "tsx src/agent/smoke_test.ts",
    "smoke:team": "tsx src/agent/team/smoke_test.ts",
    "smoke:memory": "tsx src/memory/smoke_test.ts",
    "smoke:session": "tsx src/session/smoke_test.ts",
    "feishu:config": "lark-cli config init",
    "feishu:login": "lark-cli auth login --recommend",
    "feishu:status": "lark-cli auth status",
    "feishu:doc": "lark-cli doc",
    "cron:list": "tsx src/cron/index.ts --list",
    "cron:run": "tsx src/cron/index.ts --run"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "claude"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@lancedb/lancedb": "^0.27.1",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@tavily/core": "^0.7.2",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.9.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "node-cron": "^4.2.1",
    "openai": "^4.33.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
