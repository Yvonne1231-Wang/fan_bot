{
  "name": "fan_bot",
  "version": "1.0.0",
  "description": "A lightweight, framework-free AI agent written in TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/index.ts",
    "http": "TRANSPORT=http tsx src/index.ts",
    "feishu:config": "lark-cli config init",
    "feishu:login": "lark-cli auth login --recommend",
    "feishu:status": "lark-cli auth status",
    "feishu:doc": "lark-cli doc"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "claude"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@lancedb/lancedb": "^0.27.1",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@tavily/core": "^0.7.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "openai": "^4.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}